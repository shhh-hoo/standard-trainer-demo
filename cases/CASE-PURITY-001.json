        "value": 0.6,
        "unit": "g"
      },
      {
        "label": "hydrogen volume",
        "value": 480,
        "unit": "cm3"
      },
      {
        "label": "molar gas volume",
        "value": 24000,
        "unit": "cm3 mol-1"
      },
      {
        "label": "Ar(Mg)",
        "value": 24.0,
        "unit": ""
      }
    ],
    "targetQuantity": "percentage purity of Mg",
    "answerRequirement": "percentage"
  },
  "canonicalStrategy": {
    "strategyId": "GAS_STOICHIOMETRY_PURITY",
