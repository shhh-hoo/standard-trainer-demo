        "unit": "mol dm-3"
      },
      {
        "label": "titre 1",
        "value": 20.1,
        "unit": "cm3"
      },
      {
        "label": "titre 2",
        "value": 20.2,
        "unit": "cm3"
      }
    ],
    "targetQuantity": "concentration of NaOH",
    "answerRequirement": "mol dm-3 to 3 significant figures"
  },
  "canonicalStrategy": {
    "strategyId": "TITRE_MEAN_CV_RATIO_C",
    "steps": [
      {
